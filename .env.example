# Proveedor recomendado para probar con football-data.org
# Gratis: fixtures, tablas y marcadores demorados. Para live real, requiere plan Free w/ Livescores.
API_PROVIDER=football-data
FOOTBALL_DATA_KEY=TU_TOKEN_DE_FOOTBALL_DATA
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITION=WC
TOURNAMENT_START_DATE=2026-06-28
LOOKAHEAD_DAYS=30

# Alternativa gratuita sin key, si querés volver a probarla:
# API_PROVIDER=worldcup26
# WORLDCUP26_BASE_URL=https://worldcup26.ir/get/games

# Alternativa ESPN no oficial:
# API_PROVIDER=espn
# ESPN_SCOREBOARD_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world/scoreboard
# ESPN_DATES=20260628-20260719
# ESPN_LIMIT=950

# API-Football requiere plan con acceso a season=2026.
# API_PROVIDER=api-football
# API_FOOTBALL_KEY=TU_KEY_REAL
# API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# API_FOOTBALL_LEAGUE_ID=1
# API_FOOTBALL_SEASON=2026
