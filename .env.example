# Copiar este archivo como .env
PORT=3000

# mock = usa data/mock-live-results.json
# api-football = consulta API-Football / API-SPORTS
API_PROVIDER=mock

# Solo si API_PROVIDER=api-football
# Conseguí una key en API-SPORTS / API-Football y pegala acá.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# En API-Football, el ID de FIFA World Cup suele ser 1, pero confirmalo en tu panel/API.
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# El backend consulta desde esta fecha hasta unos días hacia adelante.
TOURNAMENT_START_DATE=2026-06-28
LOOKAHEAD_DAYS=14
