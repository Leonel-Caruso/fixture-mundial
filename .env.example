# Proveedor recomendado gratis para el Mundial 2026
API_PROVIDER=worldcup26

# Fuente gratuita sin API key
WORLDCUP26_BASE_URL=https://worldcup26.ir/get/games

# Alternativa ESPN no oficial, si querés probarla:
