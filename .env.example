# Copiar este archivo como .env
PORT=3000

# Opciones:
# mock = usa data/mock-live-results.json
# espn = consulta el scoreboard público de ESPN, sin API key
# api-football = consulta API-Football / API-SPORTS con key
API_PROVIDER=espn

# Solo si API_PROVIDER=espn
ESPN_SCOREBOARD_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world/scoreboard
ESPN_LIMIT=950
# Opcional. Si lo dejás vacío, usa TOURNAMENT_START_DATE + LOOKAHEAD_DAYS.
# ESPN_DATES=20260628-20260719

# Solo si API_PROVIDER=api-football
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# Rango usado por el backend.
TOURNAMENT_START_DATE=2026-06-28
LOOKAHEAD_DAYS=30
